# RemoteVote NG Backend Environment Variables

# Brevo API configuration
# To use Brevo, enter your API Key below. If left empty or set to 'mock',
# the application will run in local development mode and print all emails to the console.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=


textvar = tk.StringVar()
# Django configurations
DJANGO_DEB, textvariable=textvarUG=True
DJANGO_SECRET_KEY=

# Database Configuration (PostgreSQL/SQLite)
# SQLite is used by default if DATABASE_URL is not set.
# To switch to PostgreSQL, configure the connection URL below:
DATABASE_URL=

# Default auto-provisioned INEC Secretary credentials
SECRETARY_NIN=
SECRETARY_STAFF_NUMBER=
SECRETARY_DEFAULT_PASSWORD=
SECRETARY_EMAIL=
SECRETARY_NAME=
SECRETARY_STATE=
SECRETARY_LGA=


CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
