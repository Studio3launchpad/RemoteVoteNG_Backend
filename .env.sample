# RemoteVote NG Backend Environment Variables (example)

# -------------------------
# Django
# -------------------------
DJANGO_SECRET_KEY=change-me-to-a-secure-random-value
DJANGO_DEBUG=True

# -------------------------
# Database
# -------------------------
# Leave empty to use SQLite (development)
# For Postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# -------------------------
# Brevo (Transactional Email)
# -------------------------
# Set to 'mock' to disable real emails and log to console
BREVO_API_KEY=mock
BREVO_SENDER_EMAIL=noreply@remotevoteng.org
BREVO_SENDER_NAME="RemoteVote NG"

# -------------------------
# Application settings
# -------------------------
ELECTION_CLOSURE_SIGNATURES_REQUIRED=2
FRONTEND_URL=http://localhost:3000

# -------------------------
# Auto-provisioned INEC Secretary
# -------------------------
SECRETARY_NIN=99999999999
SECRETARY_STAFF_NUMBER=INEC/FCT/SEC/2026/000001
SECRETARY_DEFAULT_PASSWORD=SecPass2026!
SECRETARY_EMAIL=secretary@remotevoteng.org
SECRETARY_NAME="Your Secretary Name Here"
SECRETARY_STATE=FCT
SECRETARY_LGA="Abuja Municipal"

# -------------------------
# Frontend API URLs
# -------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
REACT_APP_API_URL=http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api
NUXT_PUBLIC_API_URL=http://localhost:8000/api

NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
REACT_APP_FRONTEND_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:3000
NUXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# -------------------------
# Notes
# -------------------------
# - Never commit real secrets to version control
# - For production: set DJANGO_DEBUG=False
# - Copy this file to .env and fill in your values